# ─── Server ───────────────────────────────────────────────────────────────────
# Port the proxy server listens on. Railway injects this automatically.
PORT=3000

# Node environment: development | production
NODE_ENV=development

# ─── Forwarding ───────────────────────────────────────────────────────────────
# The upstream URL that receives the forwarded webhook payloads.
FORWARD_URL=https://www.ztake.in/api/webhooks/bank

# Timeout (ms) for the forwarding HTTP request.
REQUEST_TIMEOUT=10000

# Maximum number of retry attempts on transient forwarding failures.
MAX_RETRIES=3

# ─── Security (future use) ────────────────────────────────────────────────────
# API_KEY=
# WEBHOOK_SECRET=
